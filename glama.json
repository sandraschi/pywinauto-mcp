{
  "$schema": "https://glama.ai/mcp/schemas/server.json",
  "maintainers": [
    "sandraschi"
  ],
  "name": "pywinauto-mcp",
  "description": "Windows desktop UI automation (PyWinAuto): high privilege — read docs/SAFETY.md first. Pair with virtualization-mcp for Windows Sandbox / disposable VM isolation; HITL on mouse/keyboard, kill switch, rate limits, dry-run. FastMCP 3.1+; 8 portmanteau tools (60+ ops). Stars = distribution, not safety.",
  "type": "mcp_server",
  "status": "production",
  "framework": "FastMCP 3.1+",
  "version": "0.3.2",
  "last_sota_sync": "2026-03-21",
  "sota_version": "13.0",
  "tools": 8,
  "transport": [
    "stdio"
  ],
  "keywords": [
    "windows",
    "ui-automation",
    "pywinauto",
    "automation",
    "gui",
    "face-recognition",
    "mcp-server",
    "fastmcp",
    "sota-2026"
  ],
  "features": {
    "window_management": {
      "enabled": true,
      "capabilities": [
        "focus",
        "move",
        "resize",
        "close",
        "wait"
      ]
    },
    "element_interaction": {
      "enabled": true,
      "capabilities": [
        "click",
        "type",
        "select",
        "drag_drop"
      ]
    },
    "mouse_control": {
      "enabled": true,
      "capabilities": [
        "absolute-move",
        "relative-move",
        "scroll"
      ]
    },
    "keyboard_input": {
      "enabled": true,
      "capabilities": [
        "hotkeys",
        "text-injection",
        "ime-support"
      ]
    },
    "visual_operations": {
      "enabled": true,
      "features": [
        "screenshot",
        "OCR",
        "image_finding",
        "template-matching"
      ]
    },
    "face_recognition": {
      "enabled": true,
      "provider": "opencv-insightface"
    },
    "safety_and_isolation": {
      "enabled": true,
      "capabilities": [
        "env-kill-switch",
        "rate-limits",
        "dry-run",
        "hitl-mouse-keyboard",
        "pair-with-virtualization-mcp-for-sandbox-vm"
      ],
      "documentation": [
        "docs/SAFETY.md",
        "mcp-central-docs/patterns/PYWINAUTO_MCP_SAFETY.md"
      ]
    }
  }
}